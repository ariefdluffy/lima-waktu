{
  "name": "lima-waktu",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:reset:local": "node --env-file=.env.local scripts/db-reset.mjs",
    "db:push:local": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs push --force",
    "db:seed:local": "node --env-file=.env.local scripts/db-seed.mjs",
    "db:rebuild:local": "npm run db:reset:local && npm run db:push:local && npm run db:seed:local",
    "db:backup:local": "node --env-file=.env.local scripts/db-backup.mjs",
    "db:restore:local": "node --env-file=.env.local scripts/db-restore.mjs",
    "db:backup": "node --env-file=.env scripts/db-backup.mjs",
    "db:restore": "node --env-file=.env scripts/db-restore.mjs"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.20.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
}
